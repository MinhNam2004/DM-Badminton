<!DOCTYPE html>
<html>
<head>
  <title>DM Badminton</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>

    <div class="container text-center mt-5">

  <h1>🏸 DM Badminton</h1>
  <img src="/img/logo.png" width="120">

  <div class="row mt-5">

    <div class="col-md-3">
      <a href="/members" class="btn btn-dark w-100 p-4">👤 Thành viên</a>
    </div>

    <div class="col-md-3">
      <a href="/session/new" class="btn btn-primary w-100 p-4">➕ Tạo Sheet</a>
    </div>

    <div class="col-md-3">
      <a href="/history" class="btn btn-success w-100 p-4">📊 Lịch sử</a>
    </div>

    <div class="col-md-3">
      <a href="/upload" class="btn btn-warning w-100 p-4">🎥 Upload</a>
    </div>

  </div>
</div>
<div class="container mt-4">

  <h2>Thành viên</h2>

  <form action="/members/add" method="POST" enctype="multipart/form-data">
    <input name="name" class="form-control mb-2" placeholder="Tên">

    <input type="file" name="avatar" class="form-control mb-2">

    <button class="btn btn-primary">Thêm</button>
  </form>

  <div class="row mt-4">
    <% members.forEach(m => { %>
      <div class="col-md-3 text-center">
        <img src="<%= m.avatar %>" width="100" class="rounded-circle">
        <h5><%= m.name %></h5>

        <a href="/members/delete/<%= m._id %>" 
           class="btn btn-danger btn-sm"
           onclick="return confirm('Xoá thành viên này?')">
           Xoá
        </a>
      </div>
    <% }) %>
  </div>

</div>

<script>
document.querySelector("form").addEventListener("submit", function(e) {
  const name = document.querySelector("input[name='name']").value.trim();

  if (!name) {
    alert("⚠️ Bạn chưa nhập tên!");
    e.preventDefault();
  }
});
</script>
</body>
</html>