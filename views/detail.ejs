<!DOCTYPE html>
<html>
<head>
  <title>DM Badminton</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container text-center mt-5">

  <h1>🏸 DM Badminton</h1>
  <img src="/img/logo.png" width="120">

  <div class="row mt-5">

    <div class="col-md-3">
      <a href="/members" class="btn btn-dark w-100 p-4">👤 Thành viên</a>
    </div>

    <div class="col-md-3">
      <a href="/session/new" class="btn btn-primary w-100 p-4">➕ Tạo Sheet</a>
    </div>

    <div class="col-md-3">
      <a href="/history" class="btn btn-success w-100 p-4">📊 Lịch sử</a>
    </div>

    <div class="col-md-3">
      <a href="/upload" class="btn btn-warning w-100 p-4">🎥 Upload</a>
    </div>

  </div>
</div>


<div class="container mt-4">

<h2>Chi tiết ngày <%= new Date(session.date).toLocaleDateString() %></h2>

<table class="table">
  <thead>
    <tr>
      <th>Tên</th>
      <th>Số Sẹo</th>
      <th>Tiền Nước</th>
      <th>Tiền Sân</th>
      <th>Tiền Cầu</th>
      <th>Phát sinh</th>
      <th>Tổng</th>
    </tr>
  </thead>

  <tbody>
    <% session.players.forEach(p => { %>
      <tr>
        <td><%= p.name %></td>
        <td><%= p.seo %></td>
        <td><%= p.water %></td>
        <td><%= p.court %></td>
        <td><%= p.shuttle %></td>
        <td><%= p.extra %></td>
        <td><%= p.total %>đ</td>
      </tr>
    <% }) %>
  </tbody>
</table>

<h4>Tổng ngày: <%= session.totalDay %>đ</h4>

</div>


</body>
</html>